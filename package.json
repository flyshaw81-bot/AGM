{
  "name": "agm-studio",
  "version": "1.114.1",
  "description": "AGM Studio is the main editor for Atlas Generation Matrix, a procedural world and map content production tool for game development teams.",
  "license": "MIT",
  "author": "AGM Team",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "dev:5174": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test -- --run && npm run build",
    "test": "vitest",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:studio": "playwright test tests/e2e/studio-export-data-workflow.spec.ts tests/e2e/studio-editor-workflow.spec.ts tests/e2e/studio-language-switch.spec.ts",
    "test:e2e:legacy": "playwright test tests/e2e/burgs.spec.ts tests/e2e/layers.spec.ts tests/e2e/load-map.spec.ts tests/e2e/states.spec.ts tests/e2e/zones-export.spec.ts",
    "test:engine-importer-fixtures": "playwright test tests/e2e/engine-importer-fixture-automation.spec.ts",
    "validate:unity-export": "node scripts/validate-unity-export.mjs",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@playwright/test": "^1.57.0",
    "@types/d3": "^7.4.3",
    "@types/delaunator": "^5.0.3",
    "@types/lineclip": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/polylabel": "^1.1.3",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "playwright": "^1.57.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "alea": "^1.0.1",
    "d3": "^7.9.0",
    "delaunator": "^5.0.1",
    "lineclip": "^2.0.0",
    "polylabel": "^2.0.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
